APP_NAME=WasteBridge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Used for absolute URLs (e.g. proof photos). For mobile/emulators use LAN IP or 10.0.2.2.
APP_URL=http://localhost:8000

# Behind TLS-terminating proxy: set to * or comma-separated proxy IPs (see bootstrap/app.php).
# TRUSTED_PROXIES=
# Production: force https:// URLs from Laravel (see AppServiceProvider).
# FORCE_HTTPS=false

# -----------------------------------------------------------------------------
# Phase 0 — program setup (see DOCS/PROGRAM_SETUP.md)
# -----------------------------------------------------------------------------
# Deterministic staging/demo users + sample pickups. NEVER true in production.
STAGING_SEED=false

# Future: enable sandbox-only API surfaces for partners (currently documented only).
SANDBOX_API_ENABLED=false

# Phase 3 — marketplace auctions (minimum bid step, KES)
# AUCTION_MIN_INCREMENT_KES=10

# Phase 2 — auth, OTP, optional ClamAV scanning
REFRESH_TOKEN_TTL_DAYS=30
OTP_TTL_MINUTES=5
OTP_VERIFICATION_TOKEN_TTL_MINUTES=15
MALWARE_SCAN_DRIVER=null
# MALWARE_SCAN_DRIVER=clamav
CLAMSCAN_BINARY=/usr/bin/clamscan

# SMS (OTP). log = log only; twilio = Twilio REST; none = no send (testing only).
SMS_DRIVER=log
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Phase 4 — M-Pesa Daraja (STK), escrow, withdrawals
# -----------------------------------------------------------------------------
# Set MPESA_ENABLED=true and supply consumer key/secret + shortcode + passkey
# from Safaricom Developer Portal. MPESA_CALLBACK_URL must be a public HTTPS URL
# registered in Daraja (same path as POST /api/v1/webhooks/mpesa/callback).
MPESA_ENABLED=false
MPESA_BASE_URL=https://sandbox.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# MPESA_CALLBACK_URL=https://yourdomain.example/api/v1/webhooks/mpesa/callback
PLATFORM_COMMISSION_PERCENT=5
MIN_WITHDRAWAL_KES=10

# B2C wallet withdrawals (same OAuth as STK; Initiator + SecurityCredential from Daraja)
MPESA_B2C_ENABLED=false
MPESA_B2C_INITIATOR_NAME=
MPESA_B2C_SECURITY_CREDENTIAL=
# MPESA_B2C_SHORTCODE=  (defaults to MPESA_SHORTCODE)
MPESA_B2C_COMMAND_ID=BusinessPayment
# Must match routes registered in Safaricom Daraja (HTTPS in production):
# MPESA_B2C_RESULT_URL="${APP_URL}/api/v1/webhooks/mpesa/b2c/result"
# MPESA_B2C_TIMEOUT_URL="${APP_URL}/api/v1/webhooks/mpesa/b2c/timeout"

# Email receipt links when escrow releases (generator / buyer / seller)
RECEIPT_EMAIL_ENABLED=false

# Phase 5 — max distance (km) between pickup request GPS and optional proof GPS
# PROOF_GPS_MAX_DISTANCE_KM=2

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
